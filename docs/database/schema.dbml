// =============================================================
// NR-12 SaaS — Modelo BASE (v1) — DBML para dbdiagram.io
// Tenancy normalizada: account_id so nas raizes do tenant.
// Sem Fase 2, sem versionagem temporal de template.
// =============================================================

Project nr12_saas {
  database_type: 'PostgreSQL'
  Note: 'SaaS de inspeção NR-12. Multi-tenant via RLS. Versão base (v1).'
}

// ===== CAMADA 1 — REFERÊNCIA (global, sem account) =====

Table standards {
  id uuid [pk]
  code varchar [not null, unique, note: 'NR-12, NR-10']
  title varchar [not null]
  description varchar [null]
  created_at timestamptz [not null]
}

Table standard_versions {
  id uuid [pk]
  standard_id uuid [not null, ref: > standards.id]
  version_label varchar [not null, note: 'Redacao 916/2019']
  source_portaria_number varchar [null]
  source_issuing_body varchar [null]
  source_signed_date date [null]
  source_dou_date date [null]
  source_url varchar [null]
  effective_from date [null]
  effective_until date [null, note: 'null = vigente']
  status varchar [not null, note: 'draft | published | revoked']
  published_at timestamptz [null]
  created_at timestamptz [not null]
  indexes { (standard_id, version_label) [unique] }
  Note: 'O checklist COMPLETO = esta versao + todos os seus items.'
}

Table standard_sections {
  id uuid [pk]
  standard_version_id uuid [not null, ref: > standard_versions.id]
  section_type varchar [not null, note: 'module | annex']
  code varchar [not null, note: '12.1, Anexo I']
  title varchar [not null]
  position int [not null]
  created_at timestamptz [not null]
  indexes { (standard_version_id, code) [unique] }
}

Table standard_items {
  id uuid [pk]
  standard_section_id uuid [not null, ref: > standard_sections.id]
  parent_item_id uuid [null, ref: > standard_items.id, note: 'sub-item aninhado']
  number varchar [not null, note: '12.1.1']
  text text [not null]
  position int [not null]
  created_at timestamptz [not null]
  indexes { (standard_section_id, number) [unique] }
}

Table machine_types {
  id uuid [pk]
  name varchar [not null, unique]
  created_at timestamptz [not null]
}

Table machine_models {
  id uuid [pk]
  machine_type_id uuid [not null, ref: > machine_types.id]
  manufacturer varchar [not null, note: 'Siemens, WEG']
  model_code varchar [not null, note: '5123']
  created_at timestamptz [not null]
  indexes { (machine_type_id, manufacturer, model_code) [unique] }
}

Table location_types {
  id uuid [pk]
  name varchar [not null, unique]
  created_at timestamptz [not null]
}

Table risk_matrix_rules {
  probability varchar [not null, note: 'low | medium | high']
  severity varchar [not null, note: 'minor | moderate | major']
  risk_level varchar [not null, note: 'low | medium | high | critical']
  indexes { (probability, severity) [pk] }
}

// ===== FORMAS DE CHECKLIST (tenant) =====

Table checklist_templates {
  id uuid [pk]
  account_id uuid [not null, ref: > accounts.id, note: 'RAIZ do tenant']
  standard_version_id uuid [not null, ref: > standard_versions.id]
  name varchar [not null]
  description varchar [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
  Note: 'A "forma" (recorte da norma). Agnostico de maquina.'
}

Table checklist_template_sections {
  id uuid [pk]
  checklist_template_id uuid [not null, ref: > checklist_templates.id]
  standard_section_id uuid [not null, ref: > standard_sections.id, note: 'qual modulo/anexo da norma']
  position int [null]
  created_at timestamptz [not null]
  indexes { (checklist_template_id, standard_section_id) [unique] }
  Note: 'Filha do template, pai dos items. Agrupa por modulo/anexo.'
}

Table checklist_template_items {
  id uuid [pk]
  checklist_template_section_id uuid [not null, ref: > checklist_template_sections.id]
  standard_item_id uuid [not null, ref: > standard_items.id]
  position int [null]
  created_at timestamptz [not null]
  indexes { (checklist_template_section_id, standard_item_id) [unique] }
  Note: 'account deriva via section -> template.'
}

// ===== CAMADA 2 — CADASTRO (tenant) =====

Table accounts {
  id uuid [pk]
  type varchar [not null, note: 'engineer | company (gancho fase 2)']
  name varchar [not null]
  default_validity_months int [not null, note: 'default 12, >0']
  data_sharing_consent boolean [not null, note: 'gancho fase 2']
  created_at timestamptz [not null]
}

Table account_members {
  id uuid [pk]
  account_id uuid [not null, ref: > accounts.id]
  user_id uuid [not null, note: 'auth.users (Supabase)']
  role varchar [not null, note: 'owner (v1)']
  created_at timestamptz [not null]
  indexes { (account_id, user_id) [unique] }
}

Table clients {
  id uuid [pk]
  account_id uuid [not null, ref: > accounts.id, note: 'RAIZ do tenant']
  linked_account_id uuid [null, ref: > accounts.id, note: 'gancho fase 2']
  name varchar [not null]
  cnpj varchar [null, note: 'check 14 digitos']
  contact_name varchar [null]
  contact_email varchar [null]
  contact_phone varchar [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
}

Table locations {
  id uuid [pk]
  client_id uuid [not null, ref: > clients.id]
  location_type_id uuid [null, ref: > location_types.id]
  name varchar [not null]
  address varchar [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
  Note: 'account deriva via client'
}

Table machines {
  id uuid [pk]
  machine_model_id uuid [not null, ref: > machine_models.id, note: 'tipo vem via model']
  location_id uuid [not null, ref: > locations.id, note: 'cliente vem via location']
  tag varchar [not null]
  serial_number varchar [null]
  manufacture_year int [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
  Note: 'account deriva via location -> client'
}

// ===== PESSOAS / RESPONSABILIDADE TECNICA (tenant) =====

Table professionals {
  id uuid [pk]
  account_id uuid [not null, ref: > accounts.id, note: 'RAIZ do tenant']
  member_id uuid [null, ref: > account_members.id]
  full_name varchar [not null]
  crea varchar [null]
  title varchar [null]
  created_at timestamptz [not null]
}

Table arts {
  id uuid [pk]
  professional_id uuid [not null, ref: > professionals.id]
  number varchar [not null]
  issued_at date [null]
  pdf_path varchar [null]
  created_at timestamptz [not null]
  Note: 'account deriva via professional'
}

// ===== CAMADA 3 — TRANSACIONAL (tenant) =====

Table inspections {
  id uuid [pk]
  client_id uuid [not null, ref: > clients.id]
  responsible_professional_id uuid [null, ref: > professionals.id]
  art_id uuid [null, ref: > arts.id]
  status varchar [not null, note: 'in_field | completed']
  performed_on date [null]
  notes text [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
  Note: 'Servico do engenheiro, 1..N locais via scope. account deriva via client.'
}

Table inspection_scope {
  id uuid [pk]
  inspection_id uuid [not null, ref: > inspections.id]
  location_id uuid [not null, ref: > locations.id]
  created_at timestamptz [not null]
  indexes { (inspection_id, location_id) [unique] }
  Note: 'Escopo da inspecao = quais LOCAIS o servico cobre.'
}

Table checklists {
  id uuid [pk]
  machine_id uuid [not null, ref: > machines.id]
  checklist_template_id uuid [not null, ref: > checklist_templates.id, note: 'a forma aplicada']
  valid_until date [null, note: 'validade por maquina']
  status varchar [null, note: 'in_progress | completed']
  raw_whatsapp_payload json [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  Note: 'Checklist aplicado: forma X na maquina Y. Ligacao com inspecao: a definir (em aberto).'
}

Table answers {
  id uuid [pk]
  checklist_id uuid [not null, ref: > checklists.id]
  checklist_template_item_id uuid [not null, ref: > checklist_template_items.id]
  status varchar [not null, note: 'compliant | non_compliant | not_applicable']
  justification text [null, note: 'obrigatoria se non_compliant']
  probability varchar [null]
  severity varchar [null]
  risk_level varchar [null, note: 'lookup risk_matrix_rules']
  measured_value decimal [null]
  measured_unit varchar [null]
  created_at timestamptz [not null]
  indexes { (checklist_id, checklist_template_item_id) [unique] }
}

Table answer_photos {
  id uuid [pk]
  answer_id uuid [not null, ref: > answers.id]
  storage_path varchar [not null]
  position int [not null, note: 'check in (1,2,3)']
  created_at timestamptz [not null]
  indexes { (answer_id, position) [unique] }
}

Table reports {
  id uuid [pk]
  inspection_id uuid [null, ref: > inspections.id, note: 'DECISAO ABERTA: 1:1 vs consolida N']
  client_id uuid [not null, ref: > clients.id]
  report_number varchar [null]
  issued_at date [null]
  status varchar [not null, note: 'draft | in_review | final']
  ai_generated_text text [null]
  final_text text [null]
  pdf_path varchar [null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz [null]
  Note: 'account deriva via client'
}

Table action_plans {
  id uuid [pk]
  answer_id uuid [not null, ref: > answers.id, note: 'resposta non_compliant']
  description text [not null]
  responsible_name varchar [not null]
  due_date date [not null]
  status varchar [null, note: 'aberto | verificado (reinspecao)']
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

// ===== AGRUPAMENTOS =====

TableGroup referencia { standards standard_versions standard_sections standard_items machine_types machine_models location_types risk_matrix_rules }
TableGroup formas_checklist { checklist_templates checklist_template_sections checklist_template_items }
TableGroup cadastro { accounts account_members clients locations machines professionals arts }
TableGroup transacional { inspections inspection_scope checklists answers answer_photos reports action_plans }
